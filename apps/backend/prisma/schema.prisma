generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  passwordHash String
  avatarUrl    String?
  inviteCode   String   @unique @default(cuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  coupleAsUser1 Couple? @relation("User1")
  coupleAsUser2 Couple? @relation("User2")
  sentMessages  Message[] @relation("SentMessages")
  refreshTokens RefreshToken[]
  mood          Mood?

  @@index([email])
  @@index([inviteCode])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

enum CoupleStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Couple {
  id        String       @id @default(uuid())
  status    CoupleStatus @default(PENDING)

  user1Id   String       @unique
  user1     User         @relation("User1", fields: [user1Id], references: [id], onDelete: Cascade)

  user2Id   String       @unique
  user2     User         @relation("User2", fields: [user2Id], references: [id], onDelete: Cascade)

  anniversary DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  messages  Message[]
  moods     Mood[]

  @@index([user1Id])
  @@index([user2Id])
  @@index([status])
}

model Message {
  id        String   @id @default(uuid())
  coupleId  String
  couple    Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  senderId  String
  sender    User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  content   String
  imageUrl  String?
  seenAt    DateTime?
  createdAt DateTime @default(now())

  @@index([coupleId, createdAt])
  @@index([senderId])
}

model Mood {
  id        String   @id @default(uuid())
  coupleId  String
  couple    Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  emoji     String
  label     String
  updatedAt DateTime @updatedAt

  @@index([coupleId])
}
