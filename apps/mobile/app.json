{
  "expo": {
    "name": "Duet",
    "slug": "duet",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "duet",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.duet.app"
    },
    "android": {
      "package": "com.duet.app",
      "permissions": ["CAMERA", "RECORD_AUDIO"]
    },
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
